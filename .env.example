# Unified environment template for the current MVP:
# Stripe-only + video-only + polling-only
#
# Local:
#   cp .env.example .env.local
#   edit .env.local with your own values
#
# Vercel:
#   create the same keys below in Project Settings -> Environment Variables
#   use your production domain and live Stripe keys
#
# Notes:
# - `.env.local` is your private machine-specific file and should not be committed.
# - `.env.example` is the only committed env template in this repo.
# - Use `CALLBACK_HMAC_SECRET`, not the older `AI_CALLBACK_SECRET` name.
# - `DATABASE_URL` and `POSTGRES_URL` are aliases; set one of them.

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BILLING_PROVIDER=stripe

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET=replace_with_a_random_secret

# Optional OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional email login
# RESEND_API_KEY=
# RESEND_FROM=noreply@localhost

# Optional admin bootstrap
# ADMIN_EMAIL=you@example.com

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Local Postgres example:
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/pexelmuse
#
# Neon pooled example:
# DATABASE_URL=postgresql://username:password@ep-xxxx-xxxx-pooler.ap-southeast-1.aws.neon.tech/pexelmuse?sslmode=require
#
# Managed Postgres example:
DATABASE_URL=postgresql://username:password@db.example.com:5432/pexelmuse?sslmode=require
# POSTGRES_URL=postgresql://username:password@db.example.com:5432/pexelmuse?sslmode=require

# -----------------------------------------------------------------------------
# Storage (R2 / S3 compatible)
# -----------------------------------------------------------------------------
STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
STORAGE_REGION=auto
STORAGE_ACCESS_KEY=replace_with_storage_access_key
STORAGE_SECRET_KEY=replace_with_storage_secret_key
STORAGE_BUCKET=your-bucket
STORAGE_DOMAIN=https://pub-xxxxxxxxxxxxxxxxxxxx.r2.dev

# -----------------------------------------------------------------------------
# AI provider
# -----------------------------------------------------------------------------
EVOLINK_API_KEY=replace_with_evolink_api_key
# DEFAULT_AI_PROVIDER=evolink

# Callback and remote asset validation
AI_CALLBACK_URL=http://localhost:3000/api/v1/video/callback
CALLBACK_HMAC_SECRET=replace_with_callback_hmac_secret
REMOTE_ASSET_ALLOWED_HOSTS=assets.example.com,*.cloudfront.net

# Optional internal recovery endpoint auth
# VIDEO_RECOVERY_SECRET=replace_with_recovery_secret

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
STRIPE_API_KEY=sk_test_replace_with_stripe_secret
STRIPE_WEBHOOK_SECRET=whsec_replace_with_stripe_webhook_secret

NEXT_PUBLIC_STRIPE_PRO_MONTHLY_PRICE_ID=price_replace_with_pro_monthly
NEXT_PUBLIC_STRIPE_PRO_YEARLY_PRICE_ID=price_replace_with_pro_yearly
NEXT_PUBLIC_STRIPE_BUSINESS_MONTHLY_PRICE_ID=price_replace_with_business_monthly
NEXT_PUBLIC_STRIPE_BUSINESS_YEARLY_PRICE_ID=price_replace_with_business_yearly

# Optional, not required by the current MVP runtime path
# NEXT_PUBLIC_STRIPE_PRO_PRODUCT_ID=prod_replace_with_pro_product
# NEXT_PUBLIC_STRIPE_BUSINESS_PRODUCT_ID=prod_replace_with_business_product

# -----------------------------------------------------------------------------
# Analytics
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
